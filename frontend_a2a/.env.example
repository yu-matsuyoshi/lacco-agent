# AWS設定
AWS_REGION=ap-northeast-1
AWS_PROFILE=your-profile-name

# Cognito設定（CDKデプロイ後の出力から取得）
COGNITO_USER_POOL_ID=ap-northeast-1_XXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxx

# AgentCore Runtime設定（CDKデプロイ後にCLIで確認）
# aws bedrock-agentcore-control list-agent-runtimes --region ap-northeast-1 --profile your-profile
RUNTIME_ARN=arn:aws:bedrock-agentcore:ap-northeast-1:123456789012:runtime/kintai_agent_a2a-XXXXX

# API設定
API_TIMEOUT=300
