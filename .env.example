# AWS Configuration
AWS_REGION=us-east-1
#AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7ABCD1234
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key

# AgentCore Runtime
AGENTCORE_AGENT_ARN=arn:aws:bedrock-agentcore:us-east-1:123456789012:agent/your-agent-id

# Google Calendar API credentials
GOOGLE_CALENDAR_CREDENTIALS_PATH=credentials.json

# Data paths (for local development)
PROJECTS_CSV_PATH=data/projects.csv
CATEGORIES_CSV_PATH=data/categories.csv

# Data paths (for AgentCore Runtime - S3)
S3_BUCKET=your-bucket-name
S3_PROJECTS_KEY=kintai-agent/data/projects.csv
S3_CATEGORIES_KEY=kintai-agent/data/categories.csv

# Agent configuration
AGENT_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
AGENT_MAX_TOKENS=4096
AGENT_TEMPERATURE=0.0
